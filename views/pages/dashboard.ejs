<%- include('../partials/header', {
    pageCss: 'dashboard.css'
}) %>
    <div id="app">
        <%- include('../partials/sidebar') %>
        <main class="main">

            <div class="page active" id="page-dashboard">
                <div class="page-header">
                    <div class="page-title">Dashboard</div>
                    <div class="page-sub" id="dash-date">
                        Good morning — here's your overview
                    </div>
                </div>
                <div class="stats-grid">
                    <div class="stat-card gold">
                        <div class="stat-label">Current Balance</div>
                        <div class="stat-value current-balance" id="stat-balance">₹0</div>
                        <div class="stat-sub">Available funds</div>
                    </div>
                    <div class="stat-card green">
                        <div class="stat-label">Total Credits</div>
                        <div class="stat-value total-credit" id="stat-credits">₹0</div>
                        <div class="stat-sub">All-time received</div>
                    </div>
                    <div class="stat-card red">
                        <div class="stat-label">Total Debits</div>
                        <div class="stat-value total-debit" id="stat-debits">₹0</div>
                        <div class="stat-sub">All-time spent</div>
                    </div>
                    <div class="stat-card blue">
                        <div class="stat-label">Transactions</div>
                        <div class="stat-value total-transaction" id="stat-count">0</div>
                        <div class="stat-sub">Total count</div>
                    </div>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1.4fr; gap: 20px">
                    <div>
                        <div class="bank-card">
                            <div class="bank-card-chip"></div>
                            <div class="bank-card-number" id="card-number">
                                **** **** **** 0000
                            </div>
                            <div class="bank-card-row">
                                <div>
                                    <div class="bank-card-label">Card Holder</div>
                                    <div class="bank-card-val" id="card-name">—</div>
                                </div>
                                <div style="text-align: right">
                                    <div class="bank-card-label">Balance</div>
                                    <div class="bank-card-balance" id="card-balance">₹0</div>
                                </div>
                            </div>
                        </div>
                        <div class="card card-sm" style="margin-top: 0">
                            <div class="section-title" style="margin-bottom: 14px; font-size: 14px">
                                Quick Actions
                            </div>
                            <div style="
                    display: grid;
                    grid-template-columns: 1fr 1fr;
                    gap: 10px;
                  ">
                                <button class="btn btn-primary btn-sm" onclick="location.href='/transaction'"
                                    style="justify-content: center">
                                    + Transaction
                                </button>
                                <button class="btn btn-outline btn-sm" onclick="location.href='/transfer'"
                                    style="justify-content: center">
                                    Transfer
                                </button>
                                <button class="btn btn-outline btn-sm" onclick="downloadStatement()"
                                    style="justify-content: center">
                                    Download CSV
                                </button>
                                <button class="btn btn-outline btn-sm" onclick="location.href='/history'"
                                    style="justify-content: center">
                                    View History
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="card">
                        <div class="section-head">
                            <div class="section-title">Recent Transactions</div>
                            <button class="btn btn-outline btn-sm" onclick="location.href='/history'">
                                View All
                            </button>
                        </div>
                        <div class="table-wrap">
                            <table class="recent-transactions">
                                <thead>
                                    <tr>

                                        <th>Date</th>
                                        <th>Type</th>
                                        <th>Amount</th>
                                    </tr>
                                </thead>

                                <tbody id="recent-tbody">
                                    <tr>
                                        <td colspan="3">
                                            <div class="loading-overlay">
                                                <div class="spinner"></div>
                                                Loading...
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
<%- include('../partials/footer') %>