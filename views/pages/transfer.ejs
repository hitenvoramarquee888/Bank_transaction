<%- include('../partials/header', {
    pageCss: 'transfer.css'
}) %>
    <div id="app">
        <%- include('../partials/sidebar') %>
            <main class="main">
                <div class="page active" id="page-transfer">
                    <div class="page-header">
                        <div class="page-title">Transfer Funds</div>
                        <div class="page-sub">Send money to another account</div>
                    </div>
                    <div style="max-width: 560px">
                        <div class="card">
                            <div class="transfer-toggle">
                                <button class="transfer-toggle-btn active" id="t-direct"
                                    onclick="setTransferMode('direct')">
                                    Direct Account
                                </button>
                                <button class="transfer-toggle-btn" id="t-ben" onclick="setTransferMode('beneficiary')">
                                    Beneficiary
                                </button>
                            </div>
                            <div id="transfer-direct-section">
                                <div class="form-group" style="margin-bottom: 14px">
                                    <label>Receiver Account Number</label>
                                    <input type="number" id="transfer-accno" placeholder="Enter account number" />
                                </div>
                            </div>
                            <div id="transfer-ben-section" style="display: none">
                                <div class="form-group" style="margin-bottom: 14px">
                                    <label>Select Beneficiary</label>
                                    <select id="transfer-ben-select">
                                        <option value="">-- Select a beneficiary --</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-group" style="margin-bottom: 18px">
                                <label>Amount (₹)</label>
                                <input type="number" id="transfer-amount" placeholder="0.00" min="1" />
                            </div>
                            <div style="
                  background: var(--surface2);
                  border-radius: 10px;
                  padding: 14px;
                  font-size: 13px;
                  color: var(--text-dim);
                  margin-bottom: 18px;
                ">
                                <div style="display: flex; justify-content: space-between">
                                    <span>Available Balance</span><span style="
                      font-family: &quot;DM Mono&quot;, monospace;
                      color: var(--gold);
                    " id="transfer-avail">₹0</span>
                                </div>
                            </div>
                            <button class="btn btn-primary" onclick="doTransfer()"
                                style="width: 100%; justify-content: center">
                                Send Money
                            </button>
                        </div>
                    </div>
                </div>
            </main>
    </div>
    <%- include('../partials/footer') %>