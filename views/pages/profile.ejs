<%- include('../partials/header', { pageCss: 'profile.css' }) %>
    <div id="app">
        <%- include('../partials/sidebar') %>
            <main class="main">

                <!--  PROFILE  -->
                <div class="page active" id="page-profile">
                    <div class="page-header">
                        <div class="page-title">My Profile</div>
                        <div class="page-sub">View and update your account information</div>
                    </div>
                    <div class="profile-section">
                        <div class="profile-card">
                            <div class="profile-header">
                                <div class="profile-avatar" id="profile-avatar">


                                </div>
                                <input type="file" id="pic-input" accept="image/*" style="display:none"
                                    onchange="uploadProfilePic(this)" />

                                
                                <div>

                                    <div class="profile-name" id="profile-name">—</div>
                                    <div class="profile-email" id="profile-email">—</div>

                                </div>

                            </div>
                            <div class="img-upld-btn">
                                    <button class="btn btn-outline btn-sm"
                                        onclick="document.getElementById('pic-input').click()">
                                        Upload Photo
                                    </button>
                                    <button class="btn btn-outline btn-sm" id="remove-pic-btn" style="display:none"
                                        onclick="removeProfilePic()">
                                         ✖ Remove Photo
                                    </button>
                                </div>  
                            <div class="detail-row">
                                <span class="detail-key">Account No</span><span class="detail-val"
                                    id="profile-acc">—</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-key">Phone</span><span class="detail-val"
                                    id="profile-phone">—</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-key">Role</span><span class="detail-val" id="profile-role">—</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-key">Member Since</span><span class="detail-val"
                                    id="profile-joined">—</span>
                            </div>
                        </div>
                        <div class="profile-card">
                            <div class="section-title" style="margin-bottom: 20px">
                                Update Profile
                            </div>
                            <div style="display: flex; flex-direction: column; gap: 14px">
                                <div class="form-group">
                                    <label>Full Name</label>
                                    <input type="text" id="upd-name" placeholder="John Doe" />
                                </div>
                                <div class="form-group">
                                    <label>Email</label>
                                    <input type="email" id="upd-email" placeholder="john@example.com" />
                                </div>
                                <div class="form-group">
                                    <label>New Password (leave blank to keep)</label>
                                    <input type="password" id="upd-pass" placeholder="New password (optional)" />
                                </div>

                                <button class="btn btn-primary" onclick="doUpdateProfile()"
                                    style="justify-content: center">
                                    Save Changes
                                </button>
                            </div>

                            <button onclick="deleteAccount()" class="delete-btn">Delete Account</button>
                        </div>
                    </div>
                </div>
            </main>
    </div>

    <%- include('../partials/footer') %>