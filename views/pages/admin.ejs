<%- include('../partials/header', { pageCss: 'admin.css' }) %>
    <div id="app">
        <%- include('../partials/sidebar') %>
            <main class="main">

                <div class="page active" id="page-admin">
                    <div class="page-header">
                        <div class="page-title">Admin Panel</div>
                        <div class="page-sub">Search and view full user details</div>
                    </div>

                    <!-- Search Bar -->
                    <div class="card" style="margin-bottom: 20px;">
                        <div class="admin-search-row">

                            <div class="search-wrapper">
                                <input type="text" id="admin-search-input" class="input"
                                    placeholder="Search by name, email, phone or account number..." oninput="adminLiveSearch()">

                                <button type="button" class="clear-btn" onclick="inputValueRemove()">
                                    <i class="fa-solid fa-xmark" style="color: rgb(159, 168, 183);"></i>
                                </button>
                            </div>

                            <button class="btn btn-primary search-btn" onclick="adminSearchUsers()"><i
                                    class="fa-solid fa-magnifying-glass"></i> Search</button>
                        </div>
                        <select id="admin-search-scope" class="input admin-search-scope" style="max-width: 180px;">

                            <option value="active">Active Users</option>
                            <option value="deleted">Deleted Users</option>
                        </select>
                    </div>

                    <!-- User List -->
                    <div class="card" id="admin-list-card ">
                        <div class="section-bottom-line">Users :</div>
                        <div class="table-wrap admin-users-table">
                            <table id="admin-users-table">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Phone</th>
                                        <th>Account No</th>
                                        <th>Role</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody id="admin-users-tbody">
                                    <tr>
                                        <td colspan="7">
                                            <div class="loading-overlay">
                                                <div class="spinner"></div>
                                                Loading...
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                        </div>

                    </div>



                    <!-- User Detail View -->
                    <div class="card" id="admin-detail-card" style="display:none; margin-top: 20px;">
                        <div class="section-head">
                            <div class="section-bottom-line">User Details :</div>
                            <button class="btn btn-outline btn-sm" onclick="adminCloseDetails()"><i
                                    class="fa-solid fa-x" style="color: rgb(255, 255, 255);"></i></button>
                        </div>

                        <div id="admin-detail-body">
                            <!-- Basic Info -->
                            <div class="admin-detail-grid">
                                <div><strong>Name:</strong> <span id="ad-name">—</span></div>
                                <div><strong>Email:</strong> <span id="ad-email">—</span></div>
                                <div><strong>Phone:</strong> <span id="ad-phone">—</span></div>
                                <div><strong>Account Number:</strong> <span id="ad-account">—</span></div>
                                <div><strong>Role:</strong> <span id="ad-role">—</span></div>
                                <div><strong>Status:</strong> <span id="ad-status">—</span></div>
                                <div><strong>Current Balance:</strong> <span id="ad-balance">—</span></div>
                                <div><strong>Created At:</strong> <span id="ad-created">—</span></div>
                                <div id="ad-deleted-row" style="display:none;">
                                    <strong>Deleted At:</strong> <span id="ad-deletedAt">—</span>
                                </div>
                            </div>

                            <!-- Beneficiaries -->
                            <div class="section-bottom-line" style="margin-top: 24px; margin-bottom: 10px;">
                                Bank Details / Beneficiaries :
                            </div>

                            <div class="table-wrap admin-benificiaries">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>No.</th>
                                            <th>Beneficiary Name</th>
                                            <th>Account Number</th>
                                            <th>Added On</th>
                                        </tr>
                                    </thead>
                                    <tbody id="ad-beneficiaries-tbody">
                                        <tr>
                                            <td colspan="3">No beneficiaries</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                            <!-- Transaction History -->
                            <div class="section-bottom-line" style="margin-top: 24px; margin-bottom: 10px;">
                                Transaction History :
                            </div>
                            <div class="table-wrap admin-histories">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Date</th>
                                            <th>Sender</th>
                                            <th>Receiver</th>
                                            <th>Type</th>
                                            <th>Amount</th>
                                            <th>Sender A/c No</th>
                                            <th>Receiver A/c No</th>

                                        </tr>
                                    </thead>
                                    <tbody id="ad-transactions-tbody">
                                        <tr>
                                            <td colspan="5">No transactions</td>
                                        </tr>
                                    </tbody>
                                </table>
                                <div>
                                    <!-- <div class="section-title">User Details</div> -->
                                    <div style="display:flex; gap:10px; margin: 8px;">
                                        <button class="btn btn-primary btn-sm" id="ad-statement-btn"
                                            onclick="adminDownloadStatement()">
                                            Download Statement
                                        </button>
                                        <button class="btn btn-outline btn-sm"
                                            onclick="adminCloseDetails()">Close</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </main>
    </div>
    <%- include('../partials/footer') %>